clf;
n = -1:3;
x1 = [0 0 1 3 -2];
subplot(3,1,1); 
xlabel("n"); 
ylabel("x1"); 
title("signal of x1(n)"); 
plot2d3(n,x1); 
x2 = [0 1 2 3 0]; 
subplot(3,1,2); 
xlabel("n"); 
ylabel("x2"); 
title("signal of x2(n)"); 
plot2d3(n,x2); 
y = x1.*x2; 
subplot(3,1,3); 
xlabel("n"); 
ylabel("y"); 
title("signal of y(n)"); 
plot2d3(n,y);
